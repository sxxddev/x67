// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TopupStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENT
  FIXED
}

enum StockStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum HwidResetStatus {
  PENDING
  SUCCESS
  FAILED
}

enum LicenseKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id            Int                @id @default(autoincrement())
  name          String?
  username      String?            @unique
  email         String?            @unique
  password      String?
  emailVerified DateTime?
  image         String?
  balance       Float              @default(0)
  points        Int                @default(0)
  role          Role               @default(USER)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  topups        TopupTransaction[]
  pointsHistory PointsHistory[]
  couponUsage   CouponUsage[]
  hwidResets    HwidResetLog[]
  licenseKeys   LicenseKey[]
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id         String    @id @default(uuid())
  name       String    @unique
  image      String?   @db.LongText
  isFeatured Boolean   @default(false)
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]
}

model Product {
  id           String         @id @default(uuid())
  name         String
  description  String         @db.Text
  price        Float
  discount     Float?         @default(0)
  image        String?        @db.LongText
  isUnlimited  Boolean        @default(false)
  pointsEarn   Int            @default(0)
  isHot        Boolean        @default(false)
  badge               String?
  isActive            Boolean        @default(true)
  generatesLicenseKey Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  categoryId          String
  category            Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orders              Order[]
  productStock        ProductStock[]
  options             ProductOption[]
  hwidPrograms        HwidProgram[]
  licenseKeys         LicenseKey[]
}

model ProductOption {
  id         String   @id @default(uuid())
  productId  String
  label      String
  days       Int?
  price      Float
  stockCount Int      @default(0)
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([productId, sortOrder])
}

model ProductStock {
  id           String      @id @default(uuid())
  productId    String
  accountEmail String
  accountPass  String
  accountData  String?     @db.Text
  status       StockStatus @default(AVAILABLE)
  orderId      Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  order        Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId, status])
}

model Order {
  id            Int            @id @default(autoincrement())
  userId        Int
  productId     String
  productName   String
  productImage  String?        @db.Text
  price         Float
  quantity      Int            @default(1)
  totalPrice    Float
  pointsEarned  Int            @default(0)
  pointsUsed    Int            @default(0)
  couponId      String?
  couponDiscount Float         @default(0)
  productOptionId String?
  optionLabel   String?
  status        OrderStatus    @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productOption ProductOption? @relation(fields: [productOptionId], references: [id], onDelete: SetNull)
  coupon        Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)
  stockItems    ProductStock[]
  licenseKeys   LicenseKey[]
}

model LicenseKey {
  id              String           @id @default(uuid())
  key             String           @unique @db.VarChar(64)
  productId       String
  userId          Int?
  orderId         Int?
  hwid            String?          @db.VarChar(512)
  status          LicenseKeyStatus @default(ACTIVE)
  durationDays    Int?
  expiresAt       DateTime?
  lastValidatedAt DateTime?
  note            String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  order           Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId, status])
  @@index([userId])
  @@index([orderId])
}

model TopupTransaction {
  id        Int         @id @default(autoincrement())
  userId    Int
  amount    Float
  method    String      @default("PROMPTPAY")
  slipImage String?     @db.LongText
  note      String?
  status    TopupStatus @default(PENDING)
  adminNote String?
  approvedBy Int?
  approvedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coupon {
  id          String        @id @default(uuid())
  code        String        @unique
  type        CouponType    @default(PERCENT)
  value       Float
  minPurchase Float         @default(0)
  maxDiscount Float?
  usageLimit  Int?
  usedCount   Int           @default(0)
  startDate   DateTime      @default(now())
  endDate     DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orders      Order[]
  couponUsage CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(uuid())
  userId    Int
  couponId  String
  orderId   Int?
  usedAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
}

model PointsHistory {
  id          String   @id @default(uuid())
  userId      Int
  points      Int
  type        String   // EARN, REDEEM, BONUS, EXPIRE
  description String
  orderId     Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SiteSettings {
  id              String   @id @default("default")
  siteName        String   @default("x67secretme")
  siteDescription String?  @db.Text
  promptPayNumber String?
  promptPayName   String?
  pointsPerBaht   Float    @default(1)
  pointsValue     Float    @default(0.1)
  minTopup            Float    @default(10)
  maxTopup            Float    @default(10000)
  angpaoEnabled       Boolean  @default(true)
  angpaoAutoApprove   Boolean  @default(false)
  angpaoApiEndpoint   String?  @db.Text
  angpaoApiKey          String?  @db.Text
  angpaoReceiverPhone   String?
  angpaoAllowedHosts    String?  @default("gift.truemoney.com,tmn.app")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model HwidProgram {
  id              String         @id @default(uuid())
  name            String
  price           Float          @default(20)
  productId       String?
  apiEndpoint     String?        @db.Text
  apiKey          String?        @db.Text
  apiKeyHeader    String?        @default("Authorization")
  licenseKeyField String         @default("license")
  sortOrder       Int            @default(0)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  product         Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  resets          HwidResetLog[]

  @@index([isActive, sortOrder])
}

model HwidResetLog {
  id          String          @id @default(uuid())
  userId      Int
  programId   String
  licenseKey  String          @db.VarChar(512)
  price       Float
  status      HwidResetStatus @default(PENDING)
  apiResponse String?         @db.Text
  errorMsg    String?         @db.Text
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  program     HwidProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([programId])
}
