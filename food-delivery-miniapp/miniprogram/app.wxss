page {
  background: #f5f5f5;
  color: #111;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: #111;
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  padding: 24rpx;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.text-muted {
  color: #888;
}

.price {
  color: #e64340;
  font-weight: 600;
}
