.banner {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #eee;
}

.name {
  font-size: 36rpx;
  font-weight: 700;
}

.price {
  margin: 12rpx 0;
  font-size: 40rpx;
}

.store {
  margin-top: 12rpx;
}

.qty-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qty {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty button {
  width: 56rpx;
  height: 56rpx;
  padding: 0;
  line-height: 56rpx;
  margin: 0;
}
