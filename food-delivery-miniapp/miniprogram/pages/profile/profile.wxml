<view class="container">
  <view class="card profile" wx:if="{{loggedIn}}">
    <image class="avatar" src="{{user.avatar_url || '/images/avatar.png'}}" />
    <view class="name">{{user.nickname}}</view>
  </view>
  <view class="card" wx:else>
    <view class="text-muted">ยังไม่ได้เข้าสู่ระบบ</view>
    <view class="btn-primary" bindtap="onLogin">เข้าสู่ระบบ WeChat</view>
  </view>

  <view class="card menu" wx:if="{{loggedIn}}">
    <view class="menu-item" bindtap="goAddress">ที่อยู่จัดส่ง</view>
    <view class="menu-item danger" bindtap="onLogout">ออกจากระบบ</view>
  </view>
</view>
