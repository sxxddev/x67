.product .row {
  display: flex;
  gap: 20rpx;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #eee;
}

.info {
  flex: 1;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
}

.desc {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.bottom {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  margin: 0;
  background: #111;
  color: #fff;
  border-radius: 50%;
  font-size: 36rpx;
}
